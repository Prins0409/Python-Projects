{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item brd_testimonial_item_featured\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2022/10/Gorge-Koutsoudopoulos.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">George Koutsoudopoulos</div>\n      <div class=\"author_title\">CEO at tgndata</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated-tgndata-logo-1.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Having the best <strong>quality</strong> and <strong>quantity</strong> of data is the most important thing, and that&#8217;s where the combination of Bright Data and tgndata works.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/tgndata\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Yorgos-Panzaris_ConvertGroup.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Yorgos-Panzaris_ConvertGroup.png 800w, https://brightdata.com/wp-content/uploads/2022/10/updated_Yorgos-Panzaris_ConvertGroup-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/10/updated_Yorgos-Panzaris_ConvertGroup-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Yorgos Panzaris</div>\n      <div class=\"author_title\">CTO at Convert Group</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_ConvertGroup_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are really impressed with the <strong>reliability</strong>, and very happy with Bright Data overall. We have a regular communication channel with our account manager, who is very helpful.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/convert-group\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/11/v2_Cheddi-Rai_Adretriever.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/11/v2_Cheddi-Rai_Adretriever.png 800w, https://brightdata.com/wp-content/uploads/2022/11/v2_Cheddi-Rai_Adretriever-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/11/v2_Cheddi-Rai_Adretriever-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Cheddi Rai</div>\n      <div class=\"author_title\">CEO at AdRetreaver</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/11/updated1_Adretreaver_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are very pleased with the partnership with Bright Data. Everything&#8217;s been good, the network has been very <strong>stable</strong>, we’re happy with the <strong>customer service</strong> and the <strong>support</strong> staff is bar none in our book.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/adretreaver\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/08/updated_David-Barros_Worten.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/08/updated_David-Barros_Worten.png 800w, https://brightdata.com/wp-content/uploads/2022/08/updated_David-Barros_Worten-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/08/updated_David-Barros_Worten-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">David Barros</div>\n      <div class=\"author_title\">Data Scientist at Worten </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/06/Worten_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are genuinely pleased with the decision we made. The service has already added a lot of value to our business, it is <strong>easy to use, stable</strong> and <strong>robust</strong>.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/worten\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/09/updated_David-Patino_shopee-colombia.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/09/updated_David-Patino_shopee-colombia.png 800w, https://brightdata.com/wp-content/uploads/2022/09/updated_David-Patino_shopee-colombia-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/09/updated_David-Patino_shopee-colombia-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">David Patiño Montoya</div>\n      <div class=\"author_title\">Data Engineer at Shopee Colombia </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/05/SVG_Shopee_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Shopee logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The partnership with Bright Data has helped us grow our data sources to create decision-making processes that are based on multiple sources of information — allowing us to gain <strong>strategic advantages</strong> and <strong>accelerate our growth</strong> in new markets.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/shopee-colombia\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Mr.-Tariq_ZeroGravity.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Mr.-Tariq_ZeroGravity.png 800w, https://brightdata.com/wp-content/uploads/2022/10/updated_Mr.-Tariq_ZeroGravity-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/10/updated_Mr.-Tariq_ZeroGravity-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Tariq Al Hosani</div>\n      <div class=\"author_title\">CEO at Zero Gravity Solutions </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/10/Updated_ZeroGravity_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We found that when managing marketing for various social media accounts (clients), it&#8217;s critical to have a strong and dependable network on which to run our operations in order to <strong>maximize our capabilities</strong>, which Bright Data delivers.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/zero-gravity\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/09/Francisc-Czobor-from-Cars2Click.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"Francisc Czobor from Cars2Click\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/09/Francisc-Czobor-from-Cars2Click.png 800w, https://brightdata.com/wp-content/uploads/2022/09/Francisc-Czobor-from-Cars2Click-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/09/Francisc-Czobor-from-Cars2Click-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Francisc Czobor</div>\n      <div class=\"author_title\">Product owner at Cars2click</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/09/Cars2Click_logo_color-1.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We have an amazing partnership with Bright Data. I&#8217;ve worked with many companies before, but this is one of the <strong>best relationships</strong> I&#8217;ve had with a solution partner. Our account managers in the past two years have been great, and the engineering team is very professional.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/cars2click\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/07/Andrei-Yaromenko-from-Netpeak.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"Andrei Yaromenko from Netpeak\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/07/Andrei-Yaromenko-from-Netpeak.png 800w, https://brightdata.com/wp-content/uploads/2022/07/Andrei-Yaromenko-from-Netpeak-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/07/Andrei-Yaromenko-from-Netpeak-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Andrei Yaromenko</div>\n      <div class=\"author_title\">SEO Tech Lead</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/07/updated_Netpeak_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We use Bright Data’s network to collect public web data to analyze search engine result pages (SERPs). We are pleased with the <strong>quality of the network, the high success rates</strong> and <strong>the service</strong>. We couldn’t ask for a better partner.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/netpeak\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/09/updated_Clint-Ruch_KEY.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/09/updated_Clint-Ruch_KEY.png 800w, https://brightdata.com/wp-content/uploads/2022/09/updated_Clint-Ruch_KEY-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/09/updated_Clint-Ruch_KEY-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Clint Ruch</div>\n      <div class=\"author_title\">Senior Vice President of Engineering at Key Holdings</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/09/updated_Key_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The ability to work at <strong>scale</strong> has basically changed how we do things, and it has made dealing with larger clients a task that would have been impossible before.             </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/key-holdings\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=