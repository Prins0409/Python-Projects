    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Yael-Fridman_Keter.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Yael-Fridman_Keter.png 800w, https://brightdata.com/wp-content/uploads/2022/10/updated_Yael-Fridman_Keter-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/10/updated_Yael-Fridman_Keter-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Yael Fridman</div>\n      <div class=\"author_title\">Marketing Director at Keter</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Keter_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We chose Bright Insights for its ability to track sales and map our competitors&#8217; products in categories that are vital to our business.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/keter\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Jonathan-Lo_Overstock.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Jonathan-Lo_Overstock.png 800w, https://brightdata.com/wp-content/uploads/2022/10/updated_Jonathan-Lo_Overstock-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/10/updated_Jonathan-Lo_Overstock-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Jonathan Lo</div>\n      <div class=\"author_title\">Director of Customer Strategy & Insights at Overstock</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/10/updated_Overstock_logo_color.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Insights data is greatly supporting our company’s goals. The market share per product category helps us benchmark against a substantial competitor, and the supplier sales tactically helps our merchandising team expand our assortment. \n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/overstock\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Dave-Walsh_Mathison.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Dave-Walsh_Mathison.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Dave-Walsh_Mathison-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Dave-Walsh_Mathison-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Dave Walsh</div>\n      <div class=\"author_title\">Co-founder and CEO of Mathison</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Mathison-2.png\" class=\"attachment-full size-full\" alt=\"Mathison logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data has been an extremely valuable partner in helping us meet our growing demands for online data, as we’re able to outsource our data collection and management efforts.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/mathison\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_name\">Roman Hussy</div>\n      <div class=\"author_title\">Founder of Abuse.ch</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Abuse.png\" class=\"attachment-full size-full\" alt=\"Abuse logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              By using Bright Data’s services, I can overcome the bad actors’ methods and identify and separate the bad sites from the good ones. This obviously also helps the community – by letting them know about current cyber threats.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/abuse-ch\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Ronen-Yuval-Hoch_Karma.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Ronen-Yuval-Hoch_Karma.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Ronen-Yuval-Hoch_Karma-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Ronen-Yuval-Hoch_Karma-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Ronen Yuval-Hoch</div>\n      <div class=\"author_title\">Co-Founder & COO at Karma (formerly Shoptagr)</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Karma-1.png\" class=\"attachment-full size-full\" alt=\"Karma logo for testimonial from Web Unlocker AKA unblocker\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The customer service at Bright Data is amazing. They really care about their customers. Also, the quality of service from a technical point of view is great. The network is very stable and I have barely ever encountered downtime.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/karma\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Surovyi-Viacheslav_ZenMarket.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Surovyi-Viacheslav_ZenMarket.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Surovyi-Viacheslav_ZenMarket-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Surovyi-Viacheslav_ZenMarket-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Surovyi Viacheslav</div>\n      <div class=\"author_title\">Co-founder and CEO of ZenMarket Inc.</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/zenmarket.png\" class=\"attachment-full size-full\" alt=\"Zenmarket logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are reliant on