{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/04/Ben-Nelmes_NewAutomotive.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/04/Ben-Nelmes_NewAutomotive.png 800w, https://brightdata.com/wp-content/uploads/2022/04/Ben-Nelmes_NewAutomotive-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/04/Ben-Nelmes_NewAutomotive-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Ben Nelmes</div>\n      <div class=\"author_title\">Co-founder & Head of Policy at New Automotive</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/04/Updated_NewAutomotive_logo_color.svg\" class=\"attachment-full size-full\" alt=\"New AutoMotive logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Sharing environmental data allows more people to get access to it and allows more people to benefit from it. It enriches everybody else&#8217;s work and can give rise to fantastic collaboration. We&#8217;ve benefited from incredible support and collaboration with The Bright Initiative through getting access to public web data that we can use to influence government policy.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/new-automotive\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2022/04/David-Amezquita.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">David Amézquita</div>\n      <div class=\"author_title\">Product Manager at Container xChange</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/02/xChange_logo_color.svg\" class=\"attachment-full size-full\" alt=\"xChange logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Within our product focus, we need all the reliable public web data we can get, in order to provide <strong>real-time valuable insights</strong> to our customers.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/container-xchange\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/03/Riccardo-Fuzzi_MyAppFree.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/03/Riccardo-Fuzzi_MyAppFree.png 800w, https://brightdata.com/wp-content/uploads/2022/03/Riccardo-Fuzzi_MyAppFree-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/03/Riccardo-Fuzzi_MyAppFree-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Riccardo Fuzzi</div>\n      <div class=\"author_title\">CEO & Founder at MyAppFree</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/03/myAppFree_logo_color.svg\" class=\"attachment-full size-full\" alt=\"myAppFree logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Using the Bright Data network we were able to <strong>double the profit</strong> of our company.             </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/myappfree\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/03/Diego-Meneses_AutomationEmpire.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/03/Diego-Meneses_AutomationEmpire.png 800w, https://brightdata.com/wp-content/uploads/2022/03/Diego-Meneses_AutomationEmpire-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/03/Diego-Meneses_AutomationEmpire-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Diego Meneses</div>\n      <div class=\"author_title\">Executive Director, Colombia at Automation Empire</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/03/updated_July22_Automation-Empire_logo_color-2.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              To get the most <strong>reliable information</strong>, we rely on the Bright Data network, and the partnership has contributed to the <strong>precision</strong> in which we are able to conduct our operations.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/automation-empire\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2022/03/Mask-group.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"Lenilson Porath\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">Lenilson Porath</div>\n      <div class=\"author_title\">CTO at Effecti </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/02/updated_Effecti_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Effecti logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Working with Bright Data has been an <strong>amazing experience</strong>. Our account manager helps us in every aspect and makes us and our customers even more\n<strong>successful</strong>.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/effecti\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/02/Misaki-Sugawara_Butinuki.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/02/Misaki-Sugawara_Butinuki.png 800w, https://brightdata.com/wp-content/uploads/2022/02/Misaki-Sugawara_Butinuki-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/02/Misaki-Sugawara_Butinuki-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Misaki Sugawara</div>\n      <div class=\"author_title\">CEO/CTO at butinuki Co., Ltd.</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/02/V3_butinuki_logo_color-2.svg\" class=\"attachment-full size-full\" alt=\"butinuki logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are devising ways to paint a full enough picture for companies to make informed decisions that both enhance employee performance and foster more creative workflows within our client companies using insights gathered from public web data.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/butinuki\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/02/Thomas-Dillon_WIPO.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/02/Thomas-Dillon_WIPO.png 800w, https://brightdata.com/wp-content/uploads/2022/02/Thomas-Dillon_WIPO-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/02/Thomas-Dillon_WIPO-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Thomas Dillon</div>\n      <div class=\"author_title\">Legal Counsellor, WIPO</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"100\" height=\"31\" src=\"https://brightdata.com/wp-content/uploads/2022/02/Updated_Member-of-Wipo-Alert_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Member of WIPO Alert logo new\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Public web data is an invaluable source of information as to the scale and location of infringement on the Internet. We are most grateful that Bright Data’s contribution has enhanced WIPO ALERT, a voluntary program which promotes online safety by helping advertisers avoid misplacement of ads on suspected illicit websites.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/wipo-alert\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Vivek-Amilkanthawar_HRog.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/01/Vivek-Amilkanthawar_HRog.png 800w, https://brightdata.com/wp-content/uploads/2022/01/Vivek-Amilkanthawar_HRog-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/01/Vivek-Amilkanthawar_HRog-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Vivek Amilkanthawar</div>\n      <div class=\"author_title\">CTO at HRog</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Designed_HRog_logo_color.svg\" class=\"attachment-full size-full\" alt=\"HRog logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Collecting public web data from over 100 job boards and websites is something that none of our competitors are able to do, and using the products developed by Bright Data, we are uniquely positioned to stay ahead.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/hrog\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Dori-Stein.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">Dori Stein</div>\n      <div class=\"author_title\">CEO at Fornova</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/12/V2_Fornova_logo_color-1.svg\" class=\"attachment-full size-full\" alt=\"Fornova logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              ﻿Without Fornova’s vital <strong>competitive intelligence</strong> based on Bright Data, for example, our hotels are effectively flying blind and  losing revenue.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/fornova\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Nevo-David_Linvo.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/01/Nevo-David_Linvo.png 800w, https://brightdata.com/wp-content/uploads/2022/01/Nevo-David_Linvo-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/01/Nevo-David_Linvo-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Nevo David</div>\n      <div class=\"author_title\">CEO at Linvo</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Linvo_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Linvo Logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Our experience with Bright Data has been very good. They are very <strong>responsive, informative</strong> and <strong>fast</strong>.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/linvo\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n",
