{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/12/Fan-Jin_Shengsoft-Technologies.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/12/Fan-Jin_Shengsoft-Technologies.png 800w, https://brightdata.com/wp-content/uploads/2021/12/Fan-Jin_Shengsoft-Technologies-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/12/Fan-Jin_Shengsoft-Technologies-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Fan Jin</div>\n      <div class=\"author_title\">Founder and Software Developer at Shengsoft Technologies </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/12/Final_Shengsoft-Technologies_logo_color-4.svg\" class=\"attachment-full size-full\" alt=\"Shengsoft Technologies logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data really helps companies get the public web data they want and need in order to be <strong>successful</strong> and make <strong>well-informed decisions</strong>.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/shengsoft-technologies\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/12/Mark-OHara_Thrift.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/12/Mark-OHara_Thrift.png 800w, https://brightdata.com/wp-content/uploads/2021/12/Mark-OHara_Thrift-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/12/Mark-OHara_Thrift-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Mark O&#8217;Hara</div>\n      <div class=\"author_title\">Founder at THRIFT</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"73\" height=\"32\" src=\"https://brightdata.com/wp-content/uploads/2021/12/updated_Thrift_color.svg\" class=\"attachment-full size-full\" alt=\"Thrift logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              In terms of setup, the Web Scraper IDE is really simple. We&#8217;ve got an account manager that&#8217;s been brilliant and we&#8217;ve challenged Bright Data to create new data collectors that they didn’t have previously. It was a bit more technically challenging, and it&#8217;s going really well.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/thrift\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/12/updated_Todd-Wilson_Screen-scrape-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/12/updated_Todd-Wilson_Screen-scrape-1.png 800w, https://brightdata.com/wp-content/uploads/2021/12/updated_Todd-Wilson_Screen-scrape-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/12/updated_Todd-Wilson_Screen-scrape-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Todd Wilson</div>\n      <div class=\"author_title\">President at screen-scraper</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/01/Screen-Scraper_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Screen-scraper logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data is the premium service, as far as web data collection and optimization services go. It&#8217;s like flipping an on-switch. They save us so much time. Instead of having to investigate, tweak and troubleshoot, we have data that flows like water.             </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/screen-scraper\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/12/Edan-Krolewicz_ExactBuyer.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/12/Edan-Krolewicz_ExactBuyer.png 800w, https://brightdata.com/wp-content/uploads/2021/12/Edan-Krolewicz_ExactBuyer-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/12/Edan-Krolewicz_ExactBuyer-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Edan Krolewicz</div>\n      <div class=\"author_title\">Founder at ExactBuyer</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"32\" src=\"https://brightdata.com/wp-content/uploads/2021/12/Updated_ExactBuyer_color-1.svg\" class=\"attachment-full size-full\" alt=\"ExactBuyer logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Using a data collection platform has saved us at least the work of one or two full time developers at this point. And as we scale, then that number is obviously going to scale.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/exact-buyer\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2021/10/Aaron-Cowper.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">Aaron Cowper</div>\n      <div class=\"author_title\">Founder, CEO at ShopGrok</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/10/ShopGrok.png\" class=\"attachment-full size-full\" alt=\"shopgrok logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data has saved a lot of <strong>time, effort and manpower </strong>building our web data collection set-up and monitoring systems- we can rely on Bright Data to do most of that for us.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/shopgrok\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/09/Tim-Lam_Advantage-Solutions.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/09/Tim-Lam_Advantage-Solutions.png 800w, https://brightdata.com/wp-content/uploads/2021/09/Tim-Lam_Advantage-Solutions-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/09/Tim-Lam_Advantage-Solutions-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Tim Lam</div>\n      <div class=\"author_title\">National Technology Director at Canopy, Advantage Solutions</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/06/Advantage-solutions.png\" class=\"attachment-full size-full\" alt=\"Advantage Solutions Logo for Testimonial about residential IPs and the web unlocker for data collection\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data is not just a proxy network. We work with a team of talented engineers from Bright Data; I don’t know how many emails we’ve exchanged, but it’s been a great partnership. We plan to stick with Bright Data in the future to have access to all the IP addresses we need and, with that, continue to help our customers succeed with the support of the right data.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/advantage-solutions\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/08/Andries-Mooij_Superscanner.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/08/Andries-Mooij_Superscanner.png 800w, https://brightdata.com/wp-content/uploads/2021/08/Andries-Mooij_Superscanner-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/08/Andries-Mooij_Superscanner-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Andries Mooij</div>\n      <div class=\"author_title\">CTO at Superscanner</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/08/Superscanner.svg\" class=\"attachment-full size-full\" alt=\"Superscanner logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The greatest benefit of using Bright Data is that we can forget that they exist. Which basically means that aside from paying my bill, of course, I don’t need to bother myself with questions such as, &#8220;Why is this not working? What&#8217;s wrong with this? Help me with this&#8230;&#8221;            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/superscanner\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Jan-Curn_Apify.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Jan-Curn_Apify.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Jan-Curn_Apify-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Jan-Curn_Apify-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Jan Čurn</div>\n      <div class=\"author_title\">CEO at Apify</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/04/apify-1.png\" class=\"attachment-full size-full\" alt=\"Apify logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We have been using Bright Data for a few years and we are happy – there is barely any downtime and if we ever have issues, they are solved very quickly.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/apify\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Juan-Galdeano_RedPoints.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Juan-Galdeano_RedPoints.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Juan-Galdeano_RedPoints-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Juan-Galdeano_RedPoints-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Juan Galdeano</div>\n      <div class=\"author_title\">CTO at Red Points</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Red-Points.svg\" class=\"attachment-full size-full\" alt=\"Red Points\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The Bright Data Web Unlocker solution allowed Red Points to easily expand its offering to more customers and improve the quality of service to existing customers.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/red-points\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Keith-Amirault_Cervello-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Keith-Amirault_Cervello-1.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Keith-Amirault_Cervello-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Keith-Amirault_Cervello-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Keith Amirault</div>\n      <div class=\"author_title\">Manager at Cervello, an A.T Kearney Company</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Cervello.png\" class=\"attachment-full size-full\" alt=\"Cervello a Kearny Company Logo - png transparent\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              With the Bright Web Scraper IDE, we’re able to <strong>outsource</strong> our data collection efforts and get the online data we need so we can <strong>focus</strong> on our <strong>core business</strong>.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/cervello\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n",
