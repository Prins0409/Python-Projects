{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Hrishabh-Sanghvi_Railofy.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Hrishabh-Sanghvi_Railofy.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Hrishabh-Sanghvi_Railofy-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Hrishabh-Sanghvi_Railofy-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Hrishabh Sanghvi</div>\n      <div class=\"author_title\">Co-founder and CTO at Railofy</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/railofy.png\" class=\"attachment-full size-full\" alt=\"Railofy Logo transparent\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Our experience with Bright Data has been excellent. In terms of downtime or outages, if there are any, there’s very proactive communication, and it’s only ever for very short periods of time. It fits our needs perfectly.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/railofy\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Carl-Hendy_Reddico.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Carl-Hendy_Reddico.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Carl-Hendy_Reddico-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Carl-Hendy_Reddico-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Carl Hendy</div>\n      <div class=\"author_title\">Co-owner of Reddico</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/reddico-1.png\" class=\"attachment-full size-full\" alt=\"Small Reddico Logo - PNG\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Through the use of Bright Data&#8217;s technology, which allows Reddico to collect data at scale from any region in the world, we’re able to get cleaner, more accurate data than alternative data sources.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/reddico\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Pavel-Vlasov_AppFollow.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Pavel-Vlasov_AppFollow.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Pavel-Vlasov_AppFollow-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Pavel-Vlasov_AppFollow-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Pavel Vlasov</div>\n      <div class=\"author_title\">CTO & Co-founder of AppFollow</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/appfllow.svg\" class=\"attachment-full size-full\" alt=\"appfollow logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We are very pleased with the flexibility of the Bright Data service as well as the ongoing dedicated support we receive. Now that our company and customer base have grown, we turn to Bright Data to gather high-quality data at a faster and more efficient pace.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/appfollow\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"256\" height=\"256\" src=\"https://brightdata.com/wp-content/uploads/2021/02/B20B659C-5159-4400-B838-0EC89435F35E-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"Le Dinh Tuan - CEO at Faber Vietnam - Customer Testimonials Bright Web Scraper IDE product\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/B20B659C-5159-4400-B838-0EC89435F35E-1.png 256w, https://brightdata.com/wp-content/uploads/2021/02/B20B659C-5159-4400-B838-0EC89435F35E-1-150x150.png 150w\" sizes=\"(max-width: 256px) 100vw, 256px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Le Dinh Tuan</div>\n      <div class=\"author_title\">CEO at Faber Vietnam</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/faber-1.png\" class=\"attachment-full size-full\" alt=\"Faber Logo PNG small\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We have a product used by nearly 2000 companies sending a large amount of proxy requests &#8211; the stability of Bright Data’s network has been critical for the product’s success.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/faber-company\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Alessio-Cantoro_Immobiliare.it_-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Alessio-Cantoro_Immobiliare.it_-1.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Alessio-Cantoro_Immobiliare.it_-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Alessio-Cantoro_Immobiliare.it_-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Alessio Cantoro</div>\n      <div class=\"author_title\">CMO at Immobiliare.it</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"173\" height=\"29\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Immobiliare.it-logo.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data is fantastic in terms of the <strong>quality</strong> of online data we’re able to collect, as well as the <strong>speed</strong> of collecting it.             </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/immobiliare-it\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/David-Newell_FindAShot.org_.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/David-Newell_FindAShot.org_.png 800w, https://brightdata.com/wp-content/uploads/2021/02/David-Newell_FindAShot.org_-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/David-Newell_FindAShot.org_-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">David Newell</div>\n      <div class=\"author_title\">Founder of FindAShot.org</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/big-findashot.png\" class=\"attachment-full size-full\" alt=\"findashot logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The best thing about Bright Data is that it’s kind of a “set it and forget it” type of thing. It was very easy to get it up and running and after it’s all set up, it essentially runs on autopilot.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/find-a-shot\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Tejpal-Virdi_Sideman-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Tejpal-Virdi_Sideman-1.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Tejpal-Virdi_Sideman-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Tejpal-Virdi_Sideman-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Tejpal Virdi</div>\n      <div class=\"author_title\">Founder and CEO at Sideman</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Sideman-1.png\" class=\"attachment-full size-full\" alt=\"Sideman logo for Tejpal Virdi&#039;s customer testimonial\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              From the beginning, the support has been wonderful. Out of every company I’ve worked with, it’s been the best experience.              </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/sideman\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Tom-Hogans-CTO_RealArb-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Tom-Hogans-CTO_RealArb-1.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Tom-Hogans-CTO_RealArb-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Tom-Hogans-CTO_RealArb-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Tom Hogans</div>\n      <div class=\"author_title\">CTO at RealArb</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/realarb-1.svg\" class=\"attachment-full size-full\" alt=\"realarb logo SVG on transparent background\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We’ve been working with Bright Data for a little over a year. Previously one of our main challenges was constantly dealing with flakey, unreliable proxy providers. Bright Data&#8217;s stability and dependability has allowed us to focus on other revenue-generating activities.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/realarb\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_name\">Andrew Sudbury</div>\n      <div class=\"author_title\">CTO and Co-founder of Abine Inc.</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/abine-1.svg\" class=\"attachment-full size-full\" alt=\"abine\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data is the best service we have seen to-date. We’ve been pleased with the very responsive service and support that Bright Data has provided us.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/abine\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Norbert-Kardos_Post-for-Rent.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Norbert-Kardos_Post-for-Rent.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Norbert-Kardos_Post-for-Rent-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Norbert-Kardos_Post-for-Rent-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Norbert Kardos</div>\n      <div class=\"author_title\">Founder and CTO at Post for Rent </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/pst-for-rent-1.png\" class=\"attachment-full size-full\" alt=\"Post For Rent logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We’re given excellent service, and if we ever have issues or questions, they are solved very quickly. The interface is very straightforward and easy to use, and there’s not much downtime.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/post-for-rent\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n",
