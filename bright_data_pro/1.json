{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/07/Poompatai-Puntitpong_Manatal-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/07/Poompatai-Puntitpong_Manatal-1.png 800w, https://brightdata.com/wp-content/uploads/2022/07/Poompatai-Puntitpong_Manatal-1-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/07/Poompatai-Puntitpong_Manatal-1-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Poompatai Puntitpong</div>\n      <div class=\"author_title\">Software Engineer at Manatal </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/07/Updated_Manatal_logo_color-1.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The Web Scraper IDE replaced our need to use multiple tools to perform and maintain data collection operations. Overall, it contributed to <strong>drastically reducing the complexity</strong> of the process while maintaining a high degree of performance.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/manatal\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"400\" height=\"400\" src=\"https://brightdata.com/wp-content/uploads/2022/07/Sergii-Klius_from_DataOx.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"Sergii Klius from DataOx\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/07/Sergii-Klius_from_DataOx.png 400w, https://brightdata.com/wp-content/uploads/2022/07/Sergii-Klius_from_DataOx-50x50.png 50w\" sizes=\"(max-width: 400px) 100vw, 400px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Sergii Klius</div>\n      <div class=\"author_title\">Co-Founder at DataOx</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/07/NEW_DataOx_logo_color-2.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The <strong>reliable network</strong> and <strong>extensive infrastructure</strong> is what keeps our products running smoothly, allowing us to collect accurate public web data to fulfill the needs of our customers.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/dataox\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/06/Edward-Nguyen_Shopee.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/06/Edward-Nguyen_Shopee.png 800w, https://brightdata.com/wp-content/uploads/2022/06/Edward-Nguyen_Shopee-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/06/Edward-Nguyen_Shopee-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Edward Nguyen</div>\n      <div class=\"author_title\">Senior Data Scientist at Shopee Vietnam </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/05/SVG_Shopee_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Shopee logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We use Bright Data&#8217;s network to collect public web data in order to get ahead of the future developments within the e-commerce space, and help learn more about Shopee&#8217;s existing markets and its consumer shopping trends. I place a lot of <strong>trust</strong> in the solution. To me, I see Bright Data as a partner, not a product.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/shopee-vietnam\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/06/Mattan-Benyamini_Windward.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/06/Mattan-Benyamini_Windward.png 800w, https://brightdata.com/wp-content/uploads/2022/06/Mattan-Benyamini_Windward-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/06/Mattan-Benyamini_Windward-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Mattan Benyamini</div>\n      <div class=\"author_title\">Data Analyst Team Lead at Windward</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/06/updated_Windward_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Windward logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              To collect the public web data that feeds our algorithms, we use Bright Data’s Web Scraper IDE to automatically pull web data from the different shipping carrier websites. During the brief time we’ve worked together, what we have accomplished has been super productive and conducted with quick execution &#8211; formally addressing our needs as a company.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/windward\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/05/David-Wang_Reejig.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/05/David-Wang_Reejig.png 800w, https://brightdata.com/wp-content/uploads/2022/05/David-Wang_Reejig-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/05/David-Wang_Reejig-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">David Wang</div>\n      <div class=\"author_title\">Senior Data Engineer at Reejig</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/05/Reejig_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Reejig logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We have a great partnership with Bright Data, their system is stable and reliable, and our account manager is always available and very responsive. The Web Scraper IDE, in particular, is extremely helpful in collecting the relevant public web data we require &#8211; and saves us time since we don’t have to do any configuration and we can scale up very quickly and easily.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/reejig\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/05/Eduarda-Dias_Axur.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/05/Eduarda-Dias_Axur.png 800w, https://brightdata.com/wp-content/uploads/2022/05/Eduarda-Dias_Axur-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/05/Eduarda-Dias_Axur-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Eduarda Ballester Dias</div>\n      <div class=\"author_title\">Head of Finance at Axur</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/05/updated_Axur_logo_color.svg\" class=\"attachment-full size-full\" alt=\"Axur logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              You really need to know the market in order to succeed here, and working together with Bright Data we have been able to corner off a large section of the Brazilian market, considering the full platform we provide, and we have been able to focus on improving our services further in the long-run.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/axur\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"497\" height=\"358\" src=\"https://brightdata.com/wp-content/uploads/2022/05/Irwan-Djoehana-1.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" />        <div class=\"hes_video\">\n                          <svg role=\"presentation\">\n                <use href=\"#hes_video\"></use>\n              </svg>\n                    </div>\n      </div>\n                <div class=\"author_name\">Irwan Djoehana</div>\n      <div class=\"author_title\">Founder at Retail Shake </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/05/retail-shake_logo_color-1.svg\" class=\"attachment-full size-full\" alt=\"\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We plan to become one of the leaders in Europe for data projects dedicated to marketing intelligence, and Bright Data acts as an honorary member of our team, keeping our <strong>future success</strong> in mind.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/retail-shake\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/04/Shraddha-Bhattad_CommerceIQ.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/04/Shraddha-Bhattad_CommerceIQ.png 800w, https://brightdata.com/wp-content/uploads/2022/04/Shraddha-Bhattad_CommerceIQ-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/04/Shraddha-Bhattad_CommerceIQ-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Shraddha Bhattad</div>\n      <div class=\"author_title\">Software Development Engineer II at CommerceIQ</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/04/updated_CommerceIQ_logo_color.svg\" class=\"attachment-full size-full\" alt=\"CommerceIQ logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Considering the size of our operations, we chose Bright Data because we wanted a reliable, consistent web data collection solution working at scale. We didn’t want to end up in a situation where we have to play with fire all the time.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/commerceiq\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/04/Rick-McGraw_Black-Oak-Analytics.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/04/Rick-McGraw_Black-Oak-Analytics.png 800w, https://brightdata.com/wp-content/uploads/2022/04/Rick-McGraw_Black-Oak-Analytics-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/04/Rick-McGraw_Black-Oak-Analytics-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Rick McGraw</div>\n      <div class=\"author_title\">CEO at Black Oak Analytics</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n                </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Through Bright Data, we have the ability to know rather than guess about our customers. We have the data that we can ingest to actually know the customer rather than making assumptions.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/rick-mcgraw\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2022/04/Elodie-Read_Subak.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2022/04/Elodie-Read_Subak.png 800w, https://brightdata.com/wp-content/uploads/2022/04/Elodie-Read_Subak-50x50.png 50w, https://brightdata.com/wp-content/uploads/2022/04/Elodie-Read_Subak-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Elodie Read</div>\n      <div class=\"author_title\">Program Lead at The Climate Subak</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"166\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2022/04/updated_Subak_logo_grey.svg\" class=\"attachment-full size-full\" alt=\"Subak logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              My recommendation is that anyone who cares about climate change gets involved with the work that Subak is doing and the work that Bright Data are doing in order to become part of the solution.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/the-climate-subak\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n",
