{
    "success": true,
    "data": {
        "html": "<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Amir-Mendelson_PowerDrop.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Amir-Mendelson_PowerDrop.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Amir-Mendelson_PowerDrop-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Amir-Mendelson_PowerDrop-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Amir Mendelson</div>\n      <div class=\"author_title\">Founder of PowerDrop</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Powerdrop-1.png\" class=\"attachment-full size-full\" alt=\"Powerdrop logo\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The Bright Data Proxy Manager has really helped us to organize all of our proxies in one interface. The support is also excellent &#8211; whatever questions we have, they’re always answered very quickly and professionally.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/power-drop\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Ludek-Skaroupka_Dataweps.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Ludek-Skaroupka_Dataweps.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Ludek-Skaroupka_Dataweps-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Ludek-Skaroupka_Dataweps-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Ludek Skaroupka</div>\n      <div class=\"author_title\">Scrum Master at Dataweps</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Dataweps-1.png\" class=\"attachment-full size-full\" alt=\"dataweps logo PNG\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              The percentage of successful requests we send is one of the highest in the market, and the platform is easy to use. Customer support has also been great with very quick response times.\n            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/dataweps\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Glenn-Miseroy_LeadExpress.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Glenn-Miseroy_LeadExpress.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Glenn-Miseroy_LeadExpress-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Glenn-Miseroy_LeadExpress-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Glenn Miseroy</div>\n      <div class=\"author_title\">Founder and CTO at LeadExpress</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/LeadExpress.nl-1.png\" class=\"attachment-full size-full\" alt=\"LeadExpress.nl logo PNG transparent\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Bright Data’s account managers are available 24/7 &#8211; I can reach out to them whenever I want. I’m very satisfied with the technology as well, and Bright Data has helped us with the scaling of our product &#8211; we grew very fast and Bright Data enabled us to do this.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/lead-express\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Edison-Xhaqkaj_Cikisi.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Edison-Xhaqkaj_Cikisi.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Edison-Xhaqkaj_Cikisi-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Edison-Xhaqkaj_Cikisi-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Edison Xhaqkaj</div>\n      <div class=\"author_title\">CTO at Cikisi </div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/cikisi.png\" class=\"attachment-full size-full\" alt=\"cikisi logo PNG transparent\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Our platform depends on Bright Data and our experience has been very good so far. We were especially happy when the Bright Data Web Unlocker arrived &#8211; this was a step up for us.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/cikisi\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Evyatar-Korlanski_JDC-Tevet.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Evyatar-Korlanski_JDC-Tevet.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Evyatar-Korlanski_JDC-Tevet-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Evyatar-Korlanski_JDC-Tevet-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Evyatar Korlanski</div>\n      <div class=\"author_title\">Product manager at JDC Tevet</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/JDC-Israel-Tevet-1.png\" class=\"attachment-full size-full\" alt=\"JDC Israel Tevet Logo - Transparent PNG\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              We needed access to large amounts of data quickly in order to determine the feasibility of our project &#8211; we have now seen that we can indeed provide actionable job-market insights to the public. Without Bright Data&#8217;s Web Scraper IDE, it would have taken us weeks to gather the amounts of data necessary. Now we&#8217;re able to collect and customize whatever data we need in a matter of minutes.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/evyatar-korlanski\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Marina-Darlow_Sprint-COVID-19.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Marina-Darlow_Sprint-COVID-19.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Marina-Darlow_Sprint-COVID-19-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Marina-Darlow_Sprint-COVID-19-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Marina Darlow</div>\n      <div class=\"author_title\">Project Lead, Sprint COVID-19</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n                </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              In order to resolve key challenges associated with the coronavirus pandemic, we needed a fast and effective solution for mass online data collection. Bright Data&#8217;s swift collection of the online data we needed was critical to the success of our mission.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/marina-darlow\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Neal-Barsch_tenfourWest.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Neal-Barsch_tenfourWest.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Neal-Barsch_tenfourWest-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Neal-Barsch_tenfourWest-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Neal Barsch</div>\n      <div class=\"author_title\">Founder, tenfourWest</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/tenfourWest-1.png\" class=\"attachment-full size-full\" alt=\"Ten Four West small logo - png transparent aligned left\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              Our life-saving initiative&#8217;s success, providing geospatial data and tools to first-responding partners on the ground, including microdata on potentially affected persons in high transmission areas, was obviously dependent on the real-time data we were able to access with Bright Data&#8217;s technology.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/neal-barsch\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n<article class=\"brd_testimonial_item\">\n  <div class=\"brd_testimonial_item_inner\">\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_33\">\n            <div class=\"author_img\"><img width=\"800\" height=\"800\" src=\"https://brightdata.com/wp-content/uploads/2021/02/Brian-Chen_GrocerCheck.png\" class=\"brd_post_thumbnail_img wp-post-image\" alt=\"\" decoding=\"async\" loading=\"lazy\" srcset=\"https://brightdata.com/wp-content/uploads/2021/02/Brian-Chen_GrocerCheck.png 800w, https://brightdata.com/wp-content/uploads/2021/02/Brian-Chen_GrocerCheck-50x50.png 50w, https://brightdata.com/wp-content/uploads/2021/02/Brian-Chen_GrocerCheck-768x768.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" />        <div class=\"hes_video\">\n                    </div>\n      </div>\n                <div class=\"author_name\">Brian Chen</div>\n      <div class=\"author_title\">Co-founder of GrocerCheck</div>\n    </div>\n    <div class=\"brd_testimonial_item_col brd_testimonial_item_col_66\">\n      <div class=\"brd_testimonial_item_company_logo\">\n          <img width=\"160\" height=\"44\" src=\"https://brightdata.com/wp-content/uploads/2021/02/GrocerCheck-2.png\" class=\"attachment-full size-full\" alt=\"GrocerCheck logo - SMALL PNG - transparent alpha channel\" decoding=\"async\" loading=\"lazy\" />      </div>\n      <div class=\"brd_testimonial_item_content\">\n                    <div class=\"brd_testimonial_item_excerpt\">\n              As a student-run NPO dedicated to giving people the resources and knowledge they need to stay safe during the COVID-19 global pandemic, we needed access to location density data on demand. Bright Data&#8217;s technology has provided us with this, and our project has been a great success, expanding into even more states and countries.            </div>\n                  </div>\n      <a href=\"https://brightdata.com/testimonials/grocercheck\" class=\"brd_testimonial_item_rm\">\n        Read more        <svg class=\"cta_ic\" viewBox=\"0 0 10 10\">\n          <g fill-rule=\"evenodd\">\n            <path class=\"cta_ic-line_path\" d=\"M0 5h7\"\n              data-uw-styling-context=\"true\"></path>\n            <path class=\"cta_ic-tip_path\" d=\"M1 1l4 4-4 4\"\n              data-uw-styling-context=\"true\"></path>\n          </g>\n        </svg>\n      </a>\n    </div>\n  </div>\n</article>\n",
        "current_page": 7,
        "max_num_pages": 7,
        "offset": 2
    }
